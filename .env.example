# Database
DATABASE_HOSTNAME=localhost
DATABASE_PORT=5432
DATABASE_USERNAME=postgres
DATABASE_PASSWORD=your_password_here
DATABASE_NAME=ecommerce_db

# Redis
REDIS_HOSTNAME=localhost
REDIS_PORT=6379
REDIS_PASSWORD=your_redis_password_or_leave_empty
